#include <stdio.h>

int power(int x, int y)
{
    if (y == 0)
        return 1;
    else
        return x * power(x, y - 1);
}

int main()
{
    int x, y, result;

    printf("Enter base number: ");
    scanf("%d", &x);

    printf("Enter power: ");
    scanf("%d", &y);

    result = power(x, y);

    printf("Result = %d", result);

    return 0;
}
